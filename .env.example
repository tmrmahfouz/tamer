# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/tamer-platform
# أو استخدم MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tamer-platform

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-this-in-production

# JWT Secret
JWT_SECRET=your-jwt-secret-key-here-change-this-in-production

# AI Assistant (اختر واحداً - Gemini مجاني)
# احصل على مفتاح Gemini من: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# أو استخدم OpenAI (مدفوع)
# OPENAI_API_KEY=your-openai-api-key-here
